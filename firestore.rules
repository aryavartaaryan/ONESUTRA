rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── User profiles ──────────────────────────────────────────────────────
    // Any authenticated user can read profiles (for social feed names/avatars).
    // Only the owner can write their own profile.
    match /onesutra_users/{userId} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // ── Activity logs (habit tracking) ─────────────────────────────────────
    // Scoped per user — only the owner can read/write their logs.
    match /activity_logs/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // ── Wellness stories (social feed) ─────────────────────────────────────
    // Any authenticated user can read all stories (social feed).
    // Any authenticated user can create a story.
    // Only the story owner can update/delete their own story.
    match /wellness_stories/{storyId} {
      allow read:   if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && (
        !('userId' in resource.data) ||
        resource.data.userId == request.auth.uid
      );
    }

    // ── PranaVerse chat / reactions ────────────────────────────────────────
    // Authenticated users can read/write chat messages and reactions.
    match /pranaverse_chat/{document=**} {
      allow read, write: if request.auth != null;
    }
    match /reactions/{document=**} {
      allow read, write: if request.auth != null;
    }

    // ── Deny everything else by default ────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
